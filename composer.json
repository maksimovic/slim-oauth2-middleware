{
    "name": "maksimovic/slim-oauth2-middleware",
    "description": "OAuth2 middleware for use within a Slim Framework API",
    "keywords": ["slim", "oauth2", "middleware"],
    "authors": [
        {
            "name": "Chad Gray",
            "email": "chadwickgray@gmail.com",
            "role": "Developer"
        }
    ],
    "license": "MIT",
    "replace": {
        "chadicus/slim-oauth2-middleware": "self.version"
    },
    "config" : {
        "sort-packages": true
    },
    "require": {
        "php": "^8.1",
        "bshaffer/oauth2-server-php": "^1.9",
        "container-interop/container-interop": "^1.1",
        "maksimovic/psr-middleware": "^2.0",
        "maksimovic/slim-oauth2-http": "^4.0",
        "psr/http-message": "^1.0"
    },
    "require-dev": {
        "laminas/laminas-diactoros": "^2.0 || ^3.0",
        "php-di/php-di": "^5.4",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {"Chadicus\\Slim\\OAuth2\\Middleware\\" : "src"}
    },
    "autoload-dev": {
        "psr-4": {"ChadicusTest\\Slim\\OAuth2\\Middleware\\" : "tests"}
    },
    "suggest": {
        "maksimovic/slim-oauth2-routes": "Offers standard OAuth2 routes for slim applications"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-html build/coverage --coverage-clover build/logs/clover.xml",
        "cs-check": "phpcs"
    }
}
